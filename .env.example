# Local development env example
# Copy this file to .env and fill in your own values.
#
# NOTE: For Google auth with Supabase:
# 1. In Supabase Authentication -> URL Configuration, set Site URL to your app origin
#    and add this redirect URL: http://localhost:3000/auth/callback
# 2. In Google Cloud Console, the Authorized redirect URI should be:
#    https://<your-project-ref>.supabase.co/auth/v1/callback
# 3. In Supabase Authentication -> Providers -> Google, enable Google and use the
#    same Google client ID and secret from that Google Cloud app.

# Supabase public client keys
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-public-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-public-anon-key"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-public-anon-key"

# Supabase server-side secret
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Public app URL for generated share links
# Use your dev URL for local testing so OAuth redirect matches Supabase.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Billing provider
# `auto` prefers manual billing when configured, then QPay, then MonPay, then Stripe, then mock mode in development.
BILLING_PROVIDER="auto"
BILLING_STATE_SECRET="replace-with-a-long-random-secret"

# Manual bank transfer configuration
# Customers see these details in checkout, then submit a transfer reference for admin review.
MANUAL_BILLING_BANK_NAME="Golomt bank"
MANUAL_BILLING_ACCOUNT_NAME="Formly LLC"
MANUAL_BILLING_ACCOUNT_NUMBER="0000000000"
MANUAL_BILLING_NOTE="Use your email address as the transfer note, then submit the transfer reference in the app."
MANUAL_BILLING_PLAN_PRO_AMOUNT="35000"
MANUAL_BILLING_PLAN_TEAM_AMOUNT="70000"

# QPay configuration
# Sandbox example. For production replace these with the live merchant values QPay gives you.
# Request merchant credentials and invoice codes from QPay, then set MNT prices here.
QPAY_BASE_URL="https://merchant-sandbox.qpay.mn"
QPAY_CLIENT_ID="your-qpay-client-id"
QPAY_CLIENT_SECRET="your-qpay-client-secret"
QPAY_INVOICE_CODE_PRO="your-pro-invoice-code"
QPAY_INVOICE_CODE_TEAM="your-team-invoice-code"
QPAY_PLAN_PRO_AMOUNT="35000"
QPAY_PLAN_TEAM_AMOUNT="70000"

# MonPay configuration
# Production-ready defaults are already set for the public MonPay partner endpoints below.
MONPAY_API_BASE_URL="https://api.monpay.mn/resource/partner/v1"
MONPAY_TOKEN_URL="https://z-wallet.monpay.mn/v2/oauth/token"
MONPAY_CLIENT_ID="your-monpay-client-id"
MONPAY_CLIENT_SECRET="your-monpay-client-secret"
MONPAY_PLAN_PRO_AMOUNT="35000"
MONPAY_PLAN_TEAM_AMOUNT="70000"
MONPAY_PRODUCT_NAME="Formly subscription"
MONPAY_PRODUCT_TYPE="Software"
MONPAY_SMS_PREFIX="Formly payment"
MONPAY_SMS_SUFFIX="Confirm the payment with the TAN code."

# Stripe configuration
# Create recurring Prices in Stripe for your Pro and Team plans, then paste those IDs here.
# `sk_test_...` keeps checkout in Stripe test mode. Switch to `sk_live_...` only when ready.
# For local webhook testing you can use the Stripe CLI:
# stripe listen --forward-to http://localhost:3000/api/stripe/webhook
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_TEAM="price_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# External auth keys (Google OAuth)
# Also enable Google under Supabase Authentication -> Providers.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Optional bootstrap admins
# Comma-separated list of emails that should automatically receive the admin role after sign-in.
ADMIN_EMAILS="admin@example.com"

# AI provider configuration
# If AI_PROVIDER is not set, the app tries OpenAI first, then Gemini, then Lovable.
# In hosting dashboards like Render, save secret values without surrounding quotes.
AI_PROVIDER=gemini
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
LOVABLE_API_KEY=your-ai-service-api-key
